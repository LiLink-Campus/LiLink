# Keep source and config files consistent across Windows and Linux.
*.css text eol=lf
*.cjs text eol=lf
*.js text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.prisma text eol=lf
*.sql text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
Dockerfile text eol=lf
Caddyfile text eol=lf

# Windows command scripts conventionally use CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

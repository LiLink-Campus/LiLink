{
  "name": "lilink",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall-prisma-generate.cjs",
    "dev": "npm run build:shared && concurrently -k -n shared,web,api \"npm run dev:shared\" \"npm run dev:web:raw\" \"npm run dev:api:raw\"",
    "dev:web": "npm run build:shared && npm run dev:web:raw",
    "dev:api": "npm run build:shared && npm run dev:api:raw",
    "dev:web:raw": "npm run dev --workspace web",
    "dev:api:raw": "npm run start:dev --workspace api",
    "dev:shared": "npm run dev --workspace @lilink/shared",
    "build": "npm run build:shared && npm run typecheck:web && npm run build:web && npm run build:api",
    "build:shared": "npm run build --workspace @lilink/shared",
    "build:web": "npm run build --workspace web",
    "build:api": "npm run build --workspace api",
    "typecheck:web": "npm run build:shared && npm run typecheck --workspace web",
    "lint": "npm run lint:shared && npm run lint:web && npm run lint:api",
    "lint:shared": "npm run lint --workspace @lilink/shared",
    "lint:web": "npm run lint --workspace web",
    "lint:api": "npm run lint --workspace api",
    "test:shared": "npm run test --workspace @lilink/shared",
    "db:bootstrap": "npm run db:bootstrap --workspace api",
    "db:generate": "npm run prisma:generate --workspace api",
    "db:migrate": "npm run prisma:migrate --workspace api",
    "db:seed": "npm run prisma:seed --workspace api",
    "db:ensure-participants": "npm run ensure-cycle-participants --workspace api",
    "db:seed-defaults": "npm run prisma:seed-defaults --workspace api",
    "db:seed:default": "npm run prisma:seed:default --workspace api",
    "infra:up": "docker compose --profile dev-mail up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}

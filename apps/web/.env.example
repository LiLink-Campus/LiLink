# apps/web environment variables — example template (no secrets).
# Copy to .env.local for local development and adjust as needed.

# Base URL of the LiLink API consumed by the web app (client-visible).
# Defaults to http://localhost:4000/v1 in dev via the build/typecheck wrapper.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1

# Origin of the public devlog site, consumed server-side for the /updates feed
# and the nav NEW badge. Optional: defaults to https://devlog.lilink.top in
# production. In local dev, if left unset, the feed automatically falls back to
# a local Astro devlog at http://127.0.0.1:4321 (run lilink-devlog), so you
# normally leave this blank locally and only set it to point at a non-default
# devlog origin.
# DEVLOG_BASE_URL=https://devlog.lilink.top

# Optional Sentry frontend monitoring. The DSN is browser-visible, but keep
# SENTRY_AUTH_TOKEN secret; it is used only at build time to upload source maps.
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_AUTH_TOKEN=

{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "admin:create": "node scripts/create-admin.mjs",
    "prepare:prisma": "prisma generate --schema=prisma/schema.prisma",
    "build:shared": "npm run build:shared --prefix ../..",
    "build": "npm run prepare:prisma && nest build",
    "db:bootstrap": "node scripts/bootstrap-db.mjs",
    "ensure-cycle-participants": "node scripts/ensure-open-cycle-participants.mjs",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "sticky-participations:backfill": "node dist/scripts/backfill-sticky-cycle-participations.js",
    "export:anonymous-users": "node scripts/export-anonymous-user-data.mjs",
    "start": "npm run prepare:prisma && nest start",
    "start:dev": "npm run prepare:prisma && nest start --watch",
    "start:debug": "npm run prepare:prisma && nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "npm run prepare:prisma && eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "node -e \"import('./scripts/prisma-client.mjs').then((m) => m.ensureBuiltApi(['dist/prisma/seed.js'])).then(() => import('./dist/prisma/seed.js'))\"",
    "prisma:seed-defaults": "node scripts/seed-defaults.mjs",
    "prisma:seed:default": "node -e \"process.env.SEED_SCOPE='default'; import('./scripts/prisma-client.mjs').then((m) => m.ensureBuiltApi(['dist/prisma/seed.js'])).then(() => import('./dist/prisma/seed.js'))\"",
    "test": "npm run prepare:prisma && npm run build:shared && jest",
    "test:watch": "npm run prepare:prisma && npm run build:shared && jest --watch",
    "test:cov": "npm run prepare:prisma && npm run build:shared && jest --coverage",
    "test:debug": "npm run prepare:prisma && npm run build:shared && node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "npm run prepare:prisma && npm run build:shared && cross-env NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@lilink/shared": "file:../../packages/shared",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "edmonds-blossom-fixed": "^1.0.1",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.4",
    "pg": "^8.16.3",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.17",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.11",
    "@types/supertest": "^6.0.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "overrides": {
    "effect": "3.21.0",
    "path-to-regexp": "8.4.1",
    "lodash": "4.18.1",
    "@angular-devkit/core": {
      "picomatch": "4.0.4"
    },
    "fdir": {
      "picomatch": "4.0.4"
    }
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "setupFiles": [
      "<rootDir>/../test/jest.setup.ts"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@lilink/shared$": "<rootDir>/../../../packages/shared/src/index.ts"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}

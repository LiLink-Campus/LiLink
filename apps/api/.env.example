APP_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:3000
# Production (www + apex): comma-separated, must match the address bar exactly.
# CLIENT_ORIGIN=https://example.com,https://www.example.com
DATABASE_URL=postgresql://lilink:lilink@127.0.0.1:5432/lilink?schema=public
JWT_SECRET=replace-with-a-32-byte-secret
ADMIN_JWT_SECRET=replace-with-a-different-32-byte-secret
COOKIE_NAME=lilink_token
ADMIN_COOKIE_NAME=lilink_admin_token
COOKIE_DOMAIN=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=LiLink <hello@lilink.zone>
# Consumed only when creating the first admin (Docker CMD or `node scripts/bootstrap-admin.mjs`). Login at /admin uses the database, not these lines by themselves.
ADMIN_BOOTSTRAP_EMAIL=admin@lilink.zone
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-strong-admin-password
ADMIN_BOOTSTRAP_NAME=LiLink Admin
CRON_SECRET=replace-with-a-long-random-secret
